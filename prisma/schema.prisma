generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Category {
  EXAM
  EVENT
  GENERAL
}

enum Priority {
  NORMAL
  URGENT
}

model Notice {
  id          Int       @id @default(autoincrement())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}